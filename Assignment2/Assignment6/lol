class Item{
public:
	string name;
	int quantity;

	void saveToFile(){
		ofstream out("items.txt");
		if (out.is_open()){
			out << name << ", " << quantity << "\n";
			out.close();
			cout << "Item saved to file.\n";

		} else {
			cout << "Unable to open file for writing.\n";
		}
	}

	void loadFromFile(){
		ifstream in("items.txt");
		if (in.is_open()){
			string line;
			while(getline(in,line)){
				cout << "File content: " << line << "\n";
			}
